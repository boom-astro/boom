Bootstrap: docker
From: rust:1.93.1-slim-trixie

%environment
    export PATH=/app:/opt/kafka/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:/app/target/release:$LD_LIBRARY_PATH
    # Optional overrides
    export BOOM_DATABASE__HOST=localhost

%files
    Cargo.toml /app/Cargo.toml
    Cargo.lock /app/Cargo.lock
    apache-avro-macros /app/apache-avro-macros
    data/models /app/data/models
    data/ls_footprint_moc.fits /app/data/ls_footprint_moc.fits
    src /app/src

%post
    KAFKA_VERSION=4.1.1
    SCALA_VERSION=2.13
    apt-get update && \
    apt-get install -y --no-install-recommends \
      curl gcc g++ libhdf5-dev libclang-dev perl \
      make libsasl2-dev pkg-config \
      libsasl2-2 ca-certificates \
      openjdk-25-jre-headless tar xz-utils && \
    apt-get autoremove && apt-get clean && rm -rf /var/lib/apt/lists/*

    # Install CUDA toolkit runtime libraries
    CUDA_URL=https://developer.download.nvidia.com/compute/cuda/redist
    CUDNN_URL=https://developer.download.nvidia.com/compute/cudnn/redist
    CUDA_DIR=/usr/local/cuda/lib64
    mkdir -p $CUDA_DIR
    curl -fsSL ${CUDA_URL}/cuda_cudart/linux-x86_64/cuda_cudart-linux-x86_64-12.8.90-archive.tar.xz | \
      tar -xJf - --strip-components=2 -C $CUDA_DIR --wildcards '*/lib/*.so*'

    curl -fsSL ${CUDA_URL}/libcublas/linux-x86_64/libcublas-linux-x86_64-12.8.3.14-archive.tar.xz | \
      tar -xJf - --strip-components=2 -C $CUDA_DIR --wildcards '*/lib/*.so*'

    curl -fsSL ${CUDA_URL}/libcufft/linux-x86_64/libcufft-linux-x86_64-11.3.3.83-archive.tar.xz | \
      tar -xJf - --strip-components=2 -C $CUDA_DIR --wildcards '*/lib/*.so*'

    curl -fsSL ${CUDNN_URL}/cudnn/linux-x86_64/cudnn-linux-x86_64-9.20.0.48_cuda12-archive.tar.xz | \
      tar -xJf - --strip-components=2 -C $CUDA_DIR --wildcards '*/lib/*.so*'
    ldconfig

    # Install Kafka CLI tools
    curl -fsSL https://dlcdn.apache.org/kafka/${KAFKA_VERSION}/kafka_${SCALA_VERSION}-${KAFKA_VERSION}.tgz -o /tmp/kafka.tgz && \
    tar -xzf /tmp/kafka.tgz -C /opt && \
    ln -s /opt/kafka_${SCALA_VERSION}-${KAFKA_VERSION} /opt/kafka && \
    rm -f /tmp/kafka.tgz

    cd /app || exit 1
    cargo build --release

    cp /app/target/release/kafka_producer /app/kafka_producer
    cp /app/target/release/kafka_consumer /app/kafka_consumer
    cp /app/target/release/scheduler /app/scheduler
    cp /app/target/release/migrate_fp_flux /app/migrate_fp_flux
    cp /app/target/release/migrate_snr /app/migrate_snr

    # Cleanup: remove build deps and artifacts to reduce image size
    apt-get purge -y gcc g++ libhdf5-dev libclang-dev perl make libsasl2-dev pkg-config
    apt-get autoremove -y
    apt-get clean
    rm -rf /app/target /app/src /app/apache-avro-macros /app/Cargo.toml /app/Cargo.lock
    rm -rf /root/.cargo /usr/local/cargo /usr/local/rustup
    rm -rf /var/lib/apt/lists/*