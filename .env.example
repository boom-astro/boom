# Vite dev server proxy target (development only)
# Proxy URL for API requests during development
VITE_API_PROXY_TARGET=http://localhost:4000

# Kafka service domain (development and build-time)
VITE_KAFKA_DOMAIN=localhost:9092

# Release mode (build-time only)
# Set to true to restrict app to landing page only
# When enabled, other routes show a toast indicating features will be available when LSST alerts are released publicly
VITE_PRERELEASE_MODE=false

# PostHog configuration (analytics service)
VITE_PUBLIC_POSTHOG_KEY=fill-this-in
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Application configuration (runtime)
BOOM_API__DOMAIN=http://localhost:4000
STACK_NAME=boom-dev
DOMAIN=localhost
WEBAPP_DOMAIN=localhost
